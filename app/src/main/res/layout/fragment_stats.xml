<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!--line graph view where we will
        be displaying our data-->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="80dp"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="5dp">
        <com.jjoe64.graphview.GraphView
            android:id="@+id/idGraphView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="40dp"/>
        <TextView
            android:id="@+id/LabelOldestDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:rotation="270"
            android:textColor="#000000"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="20dp"/>
        <TextView
            android:id="@+id/LabelNewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:rotation="270"
            android:textColor="#000000"
            android:layout_marginEnd="-20dp"
            android:layout_marginBottom="20dp"/>
    </RelativeLayout>


    <RadioGroup
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:id="@+id/radio_group">

        <RadioButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/radio_all"
            android:checked="true"
            android:text="All data points">
        </RadioButton>
        <RadioButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/radio_7"
            android:text="Last 7 days">
        </RadioButton>
        <RadioButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/radio_30"
            android:text="Last 30 days">
        </RadioButton>
    </RadioGroup>

    <RelativeLayout android:layout_width="match_parent" android:layout_height="60dp" android:gravity="center|bottom">
        <com.google.android.material.chip.ChipGroup android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:id="@+id/chip_group">
            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true"
                android:checked="true"
                android:id="@+id/chip_days"
                android:text="Days"/>
            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true"
                android:checked="false"
                android:id="@+id/chip_weeks"
                android:text="Weeks"/>
            <com.google.android.material.chip.Chip android:layout_width="wrap_content" android:layout_height="wrap_content" android:checkable="true"
                android:checked="false"
                android:id="@+id/chip_months"
                android:text="Months"/>
        </com.google.android.material.chip.ChipGroup>
    </RelativeLayout>



</RelativeLayout>
