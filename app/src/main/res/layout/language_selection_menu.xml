<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/nav_item_selected_background"
        android:orientation="vertical"
        android:padding="4dp"

        android:layout_marginEnd="40dp">
        <TableLayout
            android:id="@+id/flag_table"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:drawable="@drawable/nav_item_selected_background">
            <TableRow
                android:id="@+id/flag_table_row"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:drawable="@drawable/nav_item_selected_background"
                android:gravity="center">
                <!-- Example view to scale language flags, will be removed -->
                <ImageView
                    android:id="@+id/img_view"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginRight="10dp"/>
            </TableRow>
        </TableLayout>
    </LinearLayout>

</RelativeLayout>